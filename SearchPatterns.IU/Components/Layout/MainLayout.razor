@inherits LayoutComponentBase

<!-- TopNavBar -->
<nav class="fixed top-0 w-full flex justify-between items-center px-8 h-16 bg-white/70 backdrop-blur-[20px] z-50 shadow-[0_12px_40px_rgba(25,28,30,0.06)]">
<div class="flex items-center gap-8">
<span class="text-xl font-bold text-blue-900 tracking-tighter font-headline">Algoritmos de busqueda </span>
<div class="hidden md:flex gap-6 items-center">
<a class="text-blue-900 font-bold border-b-2 border-blue-900 transition-colors font-headline tracking-tight text-sm" href="/">Panel Principal</a>
</div>
</div>
</nav>

<!-- SideNavBar -->
<aside class="fixed left-0 top-0 h-full flex flex-col py-8 bg-[#f2f4f6] w-72 z-40 hidden md:flex">
<div class="px-8 mb-12 mt-16">
<div class="flex items-center gap-3 mb-2">
<div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center text-on-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
</div>
<div>
<h3 class="text-lg font-bold text-blue-900 font-headline">Biblioteca de Algoritmos</h3>
</div>
</div>
</div>
<nav class="flex-1 space-y-1">
<a href="/" class="text-blue-900 font-bold bg-white/50 rounded-l-xl ml-4 pl-4 py-3 flex items-center gap-3 font-['Inter'] text-sm tracking-wide">
<span class="material-symbols-outlined">dashboard</span>
<span>Panel Principal</span>
</a>
<a class="text-slate-600 pl-8 py-3 flex items-center gap-3 font-['Inter'] text-sm tracking-wide hover:bg-white/30 transition-all" href="/waterjug">
<span class="material-symbols-outlined">water_drop</span>
<span>Jarras de Agua</span>
</a>
<a class="text-slate-600 pl-8 py-3 flex items-center gap-3 font-['Inter'] text-sm tracking-wide hover:bg-white/30 transition-all" href="/missionaries">
<span class="material-symbols-outlined">group</span>
<span>Misioneros y Caníbales</span>
</a>
        <a class="text-slate-600 pl-8 py-3 flex items-center gap-3 font-['Inter'] text-sm tracking-wide hover:bg-white/30 transition-all" href="/farmerpuzzle">
<span class="material-symbols-outlined">pets</span>
<span>Lobo, Cabra y Col</span>
</a>
<a class="text-slate-600 pl-8 py-3 flex items-center gap-3 font-['Inter'] text-sm tracking-wide hover:bg-white/30 transition-all" href="/mapcoloring">
<span class="material-symbols-outlined">palette</span>
<span>Coloreo de Mapas</span>
</a>
<a class="text-slate-600 pl-8 py-3 flex items-center gap-3 font-['Inter'] text-sm tracking-wide hover:bg-white/30 transition-all" href="/city-routing">
<span class="material-symbols-outlined">map</span>
<span>Búsqueda de Rutas</span>
</a>
</nav>
</aside>

<!-- Main Content -->
<main class="pt-24 pb-12 pl-4 pr-4 md:pl-80 md:pr-12 min-h-screen">
    @Body
</main>

<div id="blazor-error-ui" data-nosnippet>
    Ha ocurrido un error no controlado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>
