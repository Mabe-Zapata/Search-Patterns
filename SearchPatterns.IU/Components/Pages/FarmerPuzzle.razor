@page "/farmerpuzzle"
@using SearchPatterns.Application.FarmerPuzzle.DTOs
@inject HttpClient Http

<PageTitle>Lobo, Cabra y Col | Algoritmos de Búsqueda</PageTitle>

<div class="breadcrumb">
    <span>Biblioteca</span>
    <span class="separator">›</span>
    <span class="active">Lobo, Cabra y Col</span>
</div>

<header class="header-section">
    <h1>Problema del Lobo, la Cabra y la Col</h1>
    <p class="subtitle">
        Un granjero debe cruzar un río con un lobo, una cabra y una col.
        El bote solo admite al granjero y un elemento a la vez.
        Si el granjero no está presente, el lobo come a la cabra y la cabra come la col.
        El algoritmo <strong>BFS</strong> garantiza la secuencia óptima de movimientos.
    </p>
</header>

<div class="puzzle-layout">
    
    <div class="scene-card">
        <span class="badge @(Solution is not null && Solution.IsSolvable ? "active" : "inactive")">
            @(Solution is not null && Solution.IsSolvable ? "SIMULACIÓN ACTIVA" : "SIMULACIÓN INACTIVA")
        </span>

        <div class="river-scene">
          
            <div class="bank bank-left">
                <div class="bank-label">🌿 Orilla Izquierda</div>
                <div class="entities">
                    @if (CurrentStep is not null)
                    {
                        @if (CurrentStep.FarmerSide == "Left")
                        {
                            <div class="entity farmer">👨‍🌾<span>Granjero</span></div>
                        }
                        @if (CurrentStep.WolfSide == "Left")
                        {
                            <div class="entity wolf">🐺<span>Lobo</span></div>
                        }
                        @if (CurrentStep.GoatSide == "Left")
                        {
                            <div class="entity goat">🐐<span>Cabra</span></div>
                        }
                        @if (CurrentStep.CabbageSide == "Left")
                        {
                            <div class="entity cabbage">🥬<span>Col</span></div>
                        }
                    }
                    else
                    {
                        <div class="entity farmer">👨‍🌾<span>Granjero</span></div>
                        <div class="entity wolf">🐺<span>Lobo</span></div>
                        <div class="entity goat">🐐<span>Cabra</span></div>
                        <div class="entity cabbage">🥬<span>Col</span></div>
                    }
                </div>
            </div>

            <div class="river">
                <div class="river-waves">〰️〰️〰️</div>
                <div class="boat @(IsBoatRight ? "boat-right" : "boat-left")">
                    🚣
                </div>
                <div class="river-label">Río</div>
            </div>

            
            <div class="bank bank-right">
                <div class="bank-label">🏡 Orilla Derecha</div>
                <div class="entities">
                    @if (CurrentStep is not null)
                    {
                        @if (CurrentStep.FarmerSide == "Right")
                        {
                            <div class="entity farmer">👨‍🌾<span>Granjero</span></div>
                        }
                        @if (CurrentStep.WolfSide == "Right")
                        {
                            <div class="entity wolf">🐺<span>Lobo</span></div>
                        }
                        @if (CurrentStep.GoatSide == "Right")
                        {
                            <div class="entity goat">🐐<span>Cabra</span></div>
                        }
                        @if (CurrentStep.CabbageSide == "Right")
                        {
                            <div class="entity cabbage">🥬<span>Col</span></div>
                        }
                    }
                </div>
            </div>
        </div>

        @if (CurrentStep is not null)
        {
            <div class="action-banner">
                <span class="action-step">Paso @CurrentStep.StepNumber</span>
                <span class="action-text">@CurrentStep.Action</span>
            </div>
        }
    </div>

  
    <div class="controls-column">
        <div class="controls-card">
            <div class="card-title">Controles</div>

            <button class="btn btn-primary fluid" @onclick="SolveAsync" disabled="@IsLoading">
                @(IsLoading ? "Resolviendo..." : "▶ Resolver con BFS")
            </button>

            @if (Solution is not null && Solution.IsSolvable)
            {
                <div class="nav-controls">
                    <button class="btn btn-outline" @onclick="PrevStep" disabled="@(CurrentStepIndex <= 0)">◀ Anterior</button>
                    <span class="step-counter">@(CurrentStepIndex + 1) / @Solution.TotalSteps</span>
                    <button class="btn btn-outline" @onclick="NextStep" disabled="@(CurrentStepIndex >= Solution.TotalSteps - 1)">Siguiente ▶</button>
                </div>

                <button class="btn btn-secondary fluid" @onclick="ToggleAutoPlay">
                    @(IsAutoPlaying ? "⏹ Detener" : "⏩ Reproducir Auto")
                </button>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error-msg">@ErrorMessage</div>
            }
        </div>

        <div class="insight-card">
            <h4>💡 ¿Por qué BFS?</h4>
            <p>
                BFS explora todos los estados a profundidad <em>n</em> antes de pasar a <em>n+1</em>,
                garantizando así la solución con el menor número de cruces
                (Mellender, Cap. 6).
            </p>
        </div>

        @if (Solution is not null && Solution.IsSolvable)
        {
            <div class="stats-card">
                <div class="stat">
                    <span class="stat-value">@Solution.TotalSteps</span>
                    <span class="stat-label">Pasos totales</span>
                </div>
                <div class="stat">
                    <span class="stat-value">BFS</span>
                    <span class="stat-label">Algoritmo</span>
                </div>
            </div>
        }
    </div>
</div>


@if (Solution is not null && Solution.IsSolvable)
{
    <section class="trace-section">
        <div class="trace-header">
            <h2>Traza de Ejecución BFS</h2>
        </div>
        <div class="trace-list">
            @for (int i = 0; i <= CurrentStepIndex && i < Solution.Steps.Count; i++)
            {
                var step = Solution.Steps[i];
                <div class="trace-item @(i == CurrentStepIndex ? "active" : "")">
                    <div class="step-num">@step.StepNumber.ToString("D2")</div>
                    <div class="step-body">
                        <div class="step-action">@step.Action <span class="badge-small">ACCIÓN</span></div>
                        <div class="step-desc">@step.Description</div>
                    </div>
                    <div class="step-icons">
                        <span title="Granjero">👨‍🌾 @step.FarmerSide</span>
                        <span title="Lobo">🐺 @step.WolfSide</span>
                        <span title="Cabra">🐐 @step.GoatSide</span>
                        <span title="Col">🥬 @step.CabbageSide</span>
                    </div>
                </div>
            }

            @if (CurrentStepIndex >= Solution.TotalSteps - 1)
            {
                <div class="trace-complete">✅ ¡Todos cruzaron el río con éxito!</div>
            }
        </div>
    </section>
}

@code {
    private SolveFarmerResponseDto? Solution { get; set; }
    private int CurrentStepIndex { get; set; } = -1;
    private bool IsLoading { get; set; }
    private bool IsAutoPlaying { get; set; }
    private string? ErrorMessage { get; set; }

    private MoveStepDto? CurrentStep =>
        Solution?.Steps.Count > 0 && CurrentStepIndex >= 0 && CurrentStepIndex < Solution.Steps.Count
            ? Solution.Steps[CurrentStepIndex]
            : null;

    private bool IsBoatRight =>
        CurrentStep?.FarmerSide == "Right";

    private async Task SolveAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        Solution = null;
        CurrentStepIndex = -1;
        IsAutoPlaying = false;

        try
        {
            var response = await Http.GetFromJsonAsync<SolveFarmerResponseDto>("api/farmerpuzzle/solve");

            if (response is null)
            {
                ErrorMessage = "Error al procesar la respuesta del servidor.";
            }
            else if (!response.IsSolvable)
            {
                ErrorMessage = response.ErrorMessage ?? "No se encontró solución.";
            }
            else
            {
                Solution = response;
                CurrentStepIndex = 0;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void NextStep()
    {
        if (Solution is not null && CurrentStepIndex < Solution.TotalSteps - 1)
            CurrentStepIndex++;
        else
            IsAutoPlaying = false;
    }

    private void PrevStep()
    {
        if (CurrentStepIndex > 0)
        {
            CurrentStepIndex--;
            IsAutoPlaying = false;
        }
    }

    private async Task ToggleAutoPlay()
    {
        IsAutoPlaying = !IsAutoPlaying;

        while (IsAutoPlaying && Solution is not null && CurrentStepIndex < Solution.TotalSteps - 1)
        {
            NextStep();
            StateHasChanged();
            await Task.Delay(900);
        }

        IsAutoPlaying = false;
    }
}
