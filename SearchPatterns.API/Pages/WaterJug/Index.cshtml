@page
@model SearchPatterns.API.Pages.WaterJug.IndexModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Water Jug BFS Solver</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        h1 {
            text-align: center;
            color: white;
            margin-bottom: 30px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 30px;
            margin-bottom: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }

        .input-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
        }

        .input-group label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
        }

        .input-group input {
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        .input-group input:focus {
            outline: none;
            border-color: #667eea;
        }

        .btn {
            padding: 14px 32px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            width: 100%;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }

        .btn-nav {
            background: #667eea;
            color: white;
            padding: 10px 20px;
        }

        .btn-nav:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-nav:hover:not(:disabled) {
            background: #764ba2;
        }

        .jugs-container {
            display: flex;
            justify-content: center;
            gap: 60px;
            margin: 40px 0;
            flex-wrap: wrap;
        }

        .jug-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .jug-label {
            font-size: 18px;
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
        }

        .jug {
            width: 80px;
            height: 160px;
            border: 4px solid #333;
            border-top: none;
            border-radius: 0 0 12px 12px;
            position: relative;
            background: rgba(255,255,255,0.5);
            overflow: hidden;
        }

        .jug::before {
            content: '';
            position: absolute;
            top: -4px;
            left: -4px;
            right: -4px;
            height: 20px;
            border: 4px solid #333;
            border-radius: 8px;
            background: #333;
        }

        .water {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(180deg, #4fc3f7 0%, #0288d1 100%);
            transition: height 0.5s ease;
        }

        .water::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 8px;
            background: rgba(255,255,255,0.4);
        }

        .jug-amount {
            margin-top: 10px;
            font-size: 24px;
            font-weight: 700;
            color: #333;
        }

        .jug-capacity {
            font-size: 14px;
            color: #666;
        }

        .step-info {
            text-align: center;
            margin: 30px 0;
        }

        .step-number {
            font-size: 48px;
            font-weight: 700;
            color: #667eea;
        }

        .step-label {
            font-size: 18px;
            color: #666;
            margin-bottom: 10px;
        }

        .operation {
            font-size: 20px;
            color: #333;
            font-weight: 600;
            padding: 15px;
            background: #f5f5f5;
            border-radius: 8px;
            margin-top: 15px;
        }

        .navigation {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
        }

        .error-message {
            background: #ffebee;
            color: #c62828;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
        }

        .success-message {
            background: #e8f5e9;
            color: #2e7d32;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
        }

        .target-display {
            text-align: center;
            margin-top: 20px;
            padding: 15px;
            background: #fff3e0;
            border-radius: 8px;
            color: #e65100;
            font-weight: 600;
        }

        .initial-state {
            text-align: center;
            padding: 20px;
            background: #e3f2fd;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .initial-state h3 {
            color: #1565c0;
            margin-bottom: 10px;
        }

        .hidden {
            display: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🌊 Water Jug BFS Solver</h1>

        <div class="card">
            <form method="post" asp-page-handler="Solve">
                <div class="input-section">
                    <div class="input-group">
                        <label for="JugACapacity">Jarra A (litros)</label>
                        <input type="number" id="JugACapacity" name="JugACapacity" 
                               value="@Model.JugACapacity" min="1" max="100" required>
                    </div>
                    <div class="input-group">
                        <label for="JugBCapacity">Jarra B (litros)</label>
                        <input type="number" id="JugBCapacity" name="JugBCapacity" 
                               value="@Model.JugBCapacity" min="1" max="100" required>
                    </div>
                    <div class="input-group">
                        <label for="TargetAmount">Objetivo (litros)</label>
                        <input type="number" id="TargetAmount" name="TargetAmount" 
                               value="@Model.TargetAmount" min="1" max="100" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Resolver</button>
            </form>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="card">
                <div class="error-message">@Model.ErrorMessage</div>
            </div>
        }

        @if (Model.Solution != null && Model.Solution.IsSolvable)
        {
            <div class="card">
                <div class="initial-state">
                    <h3>🎯 Objetivo: @Model.TargetAmount litros</h3>
                    <p>Jarra A: @Model.JugACapacity L | Jarra B: @Model.JugBCapacity L</p>
                </div>

                <div class="jugs-container">
                    <div class="jug-wrapper">
                        <div class="jug-label">Jarra A</div>
                        <div class="jug">
                            <div class="water" id="waterA" style="height: 0%"></div>
                        </div>
                        <div class="jug-amount"><span id="amountA">0</span>L</div>
                        <div class="jug-capacity">/@Model.JugACapacity L</div>
                    </div>
                    <div class="jug-wrapper">
                        <div class="jug-label">Jarra B</div>
                        <div class="jug">
                            <div class="water" id="waterB" style="height: 0%"></div>
                        </div>
                        <div class="jug-amount"><span id="amountB">0</span>L</div>
                        <div class="jug-capacity">/@Model.JugBCapacity L</div>
                    </div>
                </div>

                <div class="step-info">
                    <div class="step-label">Paso</div>
                    <div class="step-number"><span id="currentStep">0</span> / @Model.Solution.TotalSteps</div>
                    <div class="operation" id="operationText">Presiona "Siguiente" para comenzar</div>
                </div>

                <div class="navigation">
                    <button class="btn btn-nav" id="prevBtn" onclick="prevStep()" disabled>◀ Anterior</button>
                    <button class="btn btn-nav" id="nextBtn" onclick="nextStep()">Siguiente ▶</button>
                </div>

                @if (Model.Solution.Steps.Any(s => s.JugAAmount == Model.TargetAmount || s.JugBAmount == Model.TargetAmount))
                {
                    <div class="target-display">
                        ¡Objetivo alcanzado! 🎉
                    </div>
                }
            </div>
        }
    </div>

    <script>
        @{
    List<object>? stepsList = null;
    if (Model.Solution?.Steps != null)
    {
        stepsList = Model.Solution.Steps.Select(s => new { 
            stepNumber = s.StepNumber, 
            operation = s.Operation, 
            description = s.Description, 
            jugAAmount = s.JugAAmount, 
            jugBAmount = s.JugBAmount 
        } as object).ToList();
    }
}
const steps = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stepsList ?? new List<object>()));
        let currentStepIndex = -1;
        const jugACapacity = @Model.JugACapacity;
        const jugBCapacity = @Model.JugBCapacity;
        const targetAmount = @Model.TargetAmount;

        function updateDisplay() {
            const currentStepEl = document.getElementById('currentStep');
            const amountAEl = document.getElementById('amountA');
            const amountBEl = document.getElementById('amountB');
            const waterAEl = document.getElementById('waterA');
            const waterBEl = document.getElementById('waterB');
            const operationEl = document.getElementById('operationText');
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');

            if (currentStepIndex < 0) {
                currentStepEl.textContent = '0';
                amountAEl.textContent = '0';
                amountBEl.textContent = '0';
                waterAEl.style.height = '0%';
                waterBEl.style.height = '0%';
                operationEl.textContent = 'Presiona "Siguiente" para comenzar';
                prevBtn.disabled = true;
                nextBtn.disabled = false;
            } else if (currentStepIndex < steps.length) {
                const step = steps[currentStepIndex];
                currentStepEl.textContent = step.stepNumber;
                amountAEl.textContent = step.jugAAmount;
                amountBEl.textContent = step.jugBAmount;
                waterAEl.style.height = ((step.jugAAmount / jugACapacity) * 100) + '%';
                waterBEl.style.height = ((step.jugBAmount / jugBCapacity) * 100) + '%';
                operationEl.textContent = step.description;
                prevBtn.disabled = currentStepIndex === 0;
                nextBtn.disabled = currentStepIndex >= steps.length - 1;
            }
        }

        function nextStep() {
            if (currentStepIndex < steps.length - 1) {
                currentStepIndex++;
                updateDisplay();
            }
        }

        function prevStep() {
            if (currentStepIndex > -1) {
                currentStepIndex--;
                updateDisplay();
            }
        }

        // Initialize display if solution exists
        if (steps.length > 0) {
            updateDisplay();
        }

        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowRight') {
                nextStep();
            } else if (e.key === 'ArrowLeft') {
                prevStep();
            }
        });
    </script>
</body>
</html>