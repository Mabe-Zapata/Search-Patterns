@page "/city-routing"
@using System.Text.Json
@inject HttpClient Http

<PageTitle>Buscador de Rutas Avanzado</PageTitle>

<div class="breadcrumb">
    <span>Biblioteca</span> <span class="separator">></span> <span class="active">Navegación de Ciudades</span>
</div>

<div class="header-section">
    <h1>Rutas Inteligentes</h1>
    <p class="subtitle">Descubre el trayecto óptimo entre ciudades utilizando nuestro motor heurístico A*. Diseñado para encontrar el camino más eficiente con precisión satelital.</p>
</div>

<div class="grid xl:grid-cols-12 gap-8 mb-12">
    <!-- Form Card -->
    <div class="xl:col-span-4">
        <div class="bg-white rounded-3xl p-8 shadow-[0_8px_30px_rgba(0,0,0,0.04)] border border-slate-100 h-full flex flex-col">
            <div class="flex items-center gap-4 mb-8">
                <div class="w-12 h-12 rounded-2xl bg-indigo-50 flex items-center justify-center">
                    <span class="material-symbols-outlined text-indigo-600">explore</span>
                </div>
                <h2 class="text-xl font-bold text-slate-800 font-headline">Coordenadas</h2>
            </div>

            @if(availableCities == null)
            {
                <div class="flex flex-col items-center justify-center py-12 gap-4 flex-1">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
                    <p class="text-indigo-600 font-bold animate-pulse text-sm">Sincronizando red...</p>
                </div>
            }
            else
            {
                <div class="space-y-6 flex-1">
                    <div class="form-group relative">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-3 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm text-indigo-500">my_location</span>
                            Punto de Origen
                        </label>
                        <div class="relative group/select">
                            <select class="custom-select w-full bg-slate-50 hover:bg-slate-100 border border-slate-200 focus:border-indigo-500 text-slate-800 rounded-xl px-4 py-3 appearance-none outline-none transition-all cursor-pointer font-semibold shadow-sm" @bind="originCity">
                                <option value="" disabled selected>Seleccione origen</option>
                                @foreach(var city in availableCities)
                                {
                                    <option value="@city">@city</option>
                                }
                            </select>
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within/select:text-indigo-500 pointer-events-none transition-colors">expand_more</span>
                        </div>
                    </div>
                    
                    <div class="flex justify-center -my-3 relative z-10">
                        <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center text-indigo-500 shadow-sm transition-transform hover:rotate-180 duration-500 cursor-pointer" @onclick="SwapCities">
                            <span class="material-symbols-outlined text-xl">swap_vert</span>
                        </div>
                    </div>

                    <div class="form-group relative">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-3 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm text-pink-500">location_on</span>
                            Destino Final
                        </label>
                        <div class="relative group/select">
                            <select class="custom-select w-full bg-slate-50 hover:bg-slate-100 border border-slate-200 focus:border-pink-500 text-slate-800 rounded-xl px-4 py-3 appearance-none outline-none transition-all cursor-pointer font-semibold shadow-sm" @bind="destinationCity">
                                <option value="" disabled selected>Seleccione destino</option>
                                @foreach(var city in availableCities)
                                {
                                    <option value="@city">@city</option>
                                }
                            </select>
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within/select:text-pink-500 pointer-events-none transition-colors">expand_more</span>
                        </div>
                    </div>

                    <div class="form-group relative">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-3 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm text-amber-500">psychology</span>
                            Algoritmo
                        </label>
                        <div class="relative group/select">
                            <select class="custom-select w-full bg-slate-50 hover:bg-slate-100 border border-slate-200 focus:border-amber-500 text-slate-800 rounded-xl px-4 py-3 appearance-none outline-none transition-all cursor-pointer font-semibold shadow-sm" @bind="algorithm">
                                <option value="0">Dijkstra (Búsqueda Universal)</option>
                                <option value="1">A* (Búsqueda Heurística)</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within/select:text-amber-500 pointer-events-none transition-colors">expand_more</span>
                        </div>
                    </div>
                </div>

                <button class="mt-8 w-full relative overflow-hidden rounded-xl bg-indigo-600 text-white font-bold py-4 px-6 transition-all duration-300 disabled:opacity-60 disabled:cursor-not-allowed hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-600/20" @onclick="CalculateRoute" disabled="@(isLoading || IsButtonDisabled)">
                    <div class="relative flex items-center justify-center gap-3">
                        @if(isLoading)
                        {
                            <span class="material-symbols-outlined animate-spin">refresh</span>
                            <span class="tracking-wide">Procesando...</span>
                        }
                        else
                        {
                            <span class="material-symbols-outlined">satellite_alt</span>
                            <span class="tracking-wide">Calcular Ruta Óptima</span>
                        }
                    </div>
                </button>
            }
            
            @if (errorMsg != null)
            {
                <div class="mt-6 bg-red-50 border border-red-100 text-red-600 p-4 rounded-xl flex items-start gap-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <span class="text-sm font-semibold">@errorMsg</span>
                </div>
            }
        </div>
    </div>

    <!-- Visualizer Card -->
    <div class="xl:col-span-8">
        <div class="bg-white rounded-3xl p-8 md:p-10 shadow-[0_8px_30px_rgba(0,0,0,0.04)] border border-slate-100 h-full flex flex-col relative overflow-hidden min-h-[500px]">
            <!-- Decorative dots background -->
            <div class="absolute inset-0 opacity-[0.15] pointer-events-none" style="background-image: radial-gradient(#94a3b8 2px, transparent 2px); background-size: 32px 32px;"></div>
            
            <div class="relative z-10 flex flex-col h-full">
                @if (result != null)
                {
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 mb-12">
                        <div>
                            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-50 text-green-700 font-bold text-xs uppercase tracking-wider mb-3 border border-green-200">
                                <span class="material-symbols-outlined text-sm">task_alt</span>
                                Ruta Exitosa
                            </div>
                            <h3 class="text-2xl font-black text-slate-800 font-headline">Trayectoria Generada</h3>
                        </div>
                        <div class="bg-indigo-50 rounded-2xl p-4 text-center min-w-[140px] border border-indigo-100">
                            <div class="text-[10px] text-indigo-500 font-black uppercase tracking-widest mb-1">Distancia Total</div>
                            <div class="text-3xl font-black text-indigo-900">@result.TotalDistanceKm <span class="text-sm text-indigo-500 font-bold">km</span></div>
                        </div>
                    </div>

                    <div class="flex-1 flex items-center justify-center py-10 relative overflow-x-auto pb-8">
                        <!-- Línea conectora de fondo -->
                        <div class="absolute top-1/2 left-10 right-10 h-1 bg-slate-100 -translate-y-1/2 rounded-full hidden md:block"></div>

                        <div class="path-timeline flex flex-col md:flex-row items-center justify-start md:justify-center gap-y-6 md:gap-x-2 relative z-10 min-w-max px-4 md:px-8 mx-auto w-fit">
                            @{
                                // Fallback robusto: si el backend devuelve un solo string "A -> B -> C", lo separamos correctamente aquí
                                var pathString = string.Join(" ", result.RouteDescriptions);
                                var cities = pathString.Split(new[] { "->" }, StringSplitOptions.RemoveEmptyEntries)
                                                       .Select(c => c.Trim())
                                                       .Where(c => !string.IsNullOrEmpty(c))
                                                       .ToList();

                                for (int i = 0; i < cities.Count; i++)
                                {
                                    var city = cities[i];
                                    var isFirst = i == 0;
                                    var isLast = i == cities.Count - 1;
                                    
                                    <!-- Nodo de Ciudad -->
                                    <div class="node-container animate-bounce-in shrink-0 relative group z-20" style="animation-delay: @(i * 150)ms">
                                        <!-- Efecto de Hover/Resplandor -->
                                        <div class="absolute inset-0 rounded-2xl blur-lg transition-all opacity-0 group-hover:opacity-100 @(isFirst ? "bg-indigo-400/40" : isLast ? "bg-emerald-400/40" : "bg-cyan-400/40")"></div>
                                        
                                        <div class="relative bg-white border-2 @(isFirst ? "border-indigo-500 shadow-indigo-100" : isLast ? "border-emerald-500 shadow-emerald-100" : "border-cyan-400 shadow-cyan-100") rounded-2xl px-4 py-3 shadow-md whitespace-nowrap flex flex-col items-center gap-1 transition-transform hover:-translate-y-1 cursor-default">
                                            
                                            <!-- Icono Animado -->
                                            <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-inner @(isFirst ? "bg-indigo-50 text-indigo-600" : isLast ? "bg-emerald-50 text-emerald-600" : "bg-cyan-50 text-cyan-600") relative overflow-hidden group-hover:scale-110 transition-transform duration-500">
                                                @if(isFirst) { 
                                                    <span class="material-symbols-outlined text-lg">flight_takeoff</span>
                                                }
                                                else if(isLast) { 
                                                    <span class="material-symbols-outlined text-lg">flight_land</span> 
                                                }
                                                else { 
                                                    <span class="material-symbols-outlined text-base">location_on</span> 
                                                }
                                                <div class="absolute inset-0 bg-gradient-to-b from-white/60 to-transparent opacity-50"></div>
                                            </div>

                                            <!-- Información -->
                                            <div class="text-center">
                                                <span class="block font-black text-slate-800 text-sm font-headline tracking-tight mt-1">@city</span>
                                                <div class="inline-block mt-0.5 px-2 py-0.5 rounded-full text-[8px] font-black uppercase tracking-widest @(isFirst ? "bg-indigo-100 text-indigo-700" : isLast ? "bg-emerald-100 text-emerald-700" : "bg-cyan-100 text-cyan-700")">
                                                    @(isFirst ? "Punto de Origen" : isLast ? "Destino Final" : "Ciudad en Ruta")
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Flecha Conectora -->
                                    @if (!isLast)
                                    {
                                        <div class="arrow-container hidden md:flex items-center px-1 flex-1 animate-fade-in min-w-[24px] md:min-w-[32px] max-w-[60px]" style="animation-delay: @(i * 150 + 75)ms; z-index: 10;">
                                            <!-- Línea principal con degradado -->
                                            <div class="h-1.5 w-full bg-gradient-to-r from-indigo-200 via-cyan-300 to-emerald-200 relative rounded-full shadow-inner">
                                                <!-- Efecto de luz corriendo -->
                                                <div class="absolute inset-0 overflow-hidden rounded-full">
                                                     <div class="h-full w-1/2 bg-white/80 blur-[1px] animate-shimmer"></div>
                                                </div>
                                                <!-- Punta de flecha robusta -->
                                                <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1 border-y-[4px] border-y-transparent border-l-[6px] border-l-emerald-300 drop-shadow-md"></div>
                                            </div>
                                        </div>

                                        <!-- Conector vertical para móviles -->
                                        <div class="arrow-container-mobile md:hidden h-8 w-1.5 bg-gradient-to-b from-indigo-200 via-cyan-300 to-emerald-200 rounded-full animate-fade-in relative shadow-inner" style="animation-delay: @(i * 150 + 75)ms">
                                            <div class="absolute inset-0 overflow-hidden rounded-full">
                                                <div class="w-full h-1/2 bg-white/80 blur-[1px] animate-shimmer-vertical"></div>
                                            </div>
                                            <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1 border-x-[4px] border-x-transparent border-t-[6px] border-t-emerald-300 drop-shadow-md"></div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>
                }
                else if (!isLoading)
                {
                    <div class="h-full flex flex-col items-center justify-center text-center p-12">
                        <div class="w-20 h-20 mb-6 rounded-full bg-slate-50 flex items-center justify-center border border-slate-100">
                            <span class="material-symbols-outlined text-4xl text-slate-300">travel_explore</span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-700 mb-2 font-headline">Esperando Coordenadas</h3>
                        <p class="text-slate-500 text-sm max-w-sm">Selecciona tu punto de partida y destino para trazar la ruta óptima a través de la red de ciudades.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Explicación Sencilla de los Algoritmos -->
<div class="insight-card mb-12">
    <div class="insight-icon">
        <span class="material-symbols-outlined">lightbulb</span>
    </div>
    <div class="insight-content">
        <h4>¿Cómo funcionan nuestros algoritmos?</h4>
        
        @if (algorithm == 0)
        {
            <div class="mb-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
                <h5 class="flex items-center gap-2 font-bold text-blue-700 mb-2">
                    <span class="material-symbols-outlined">hub</span>
                    Dijkstra (Búsqueda Universal)
                </h5>
                <p class="text-sm text-blue-800 mb-3">Este algoritmo funciona como una <strong>"ola de agua"</strong> que se expande uniformemente en todas las direcciones desde el punto de origen.</p>
                <ul class="text-sm text-blue-800 space-y-1">
                    <li>• <strong>g(n) = costo desde el origen</strong>: Calcula cuántos km hemos recorrido desde que salimos.</li>
                    <li>• Explora <strong>todas las ciudades vecinas</strong> sin distinción.</li>
                    <li>• <strong>Garantiza</strong> encontrar la ruta más corta.</li>
                    <li>• Pero puede explorar <strong>muchas ciudades innecesarias</strong>.</li>
                </ul>
            </div>
            
            <div class="p-4 bg-amber-50 rounded-xl border border-amber-100">
                <h5 class="flex items-center gap-2 font-bold text-amber-700 mb-2">
                    <span class="material-symbols-outlined">smart_toy</span>
                    Actualmente: Explorando con Dijkstra
                </h5>
                <p class="text-sm text-amber-800">
                    El algoritmo está calculando el <strong>costo acumulado (g)</strong> desde <strong>@originCity</strong> hacia cada ciudad邻居, 
                    expandiéndose como una ola en todas direcciones. Necesita explorar prácticamente todo el mapa para encontrar el destino.
                </p>
            </div>
        }
        else
        {
            <div class="mb-4 p-4 bg-purple-50 rounded-xl border border-purple-100">
                <h5 class="flex items-center gap-2 font-bold text-purple-700 mb-2">
                    <span class="material-symbols-outlined">psychology</span>
                    A* (Búsqueda Heurística)
                </h5>
                <p class="text-sm text-purple-800 mb-3">Este algoritmo es <strong>inteligente</strong>. Para cada ciudad intermedia, calcula dos valores y los suma:</p>
                <ul class="text-sm text-purple-800 space-y-1">
                    <li>• <strong>g(n) = costo real</strong>: Cuántos km de carretera hemos recorrido desde el origen.</li>
                    <li>• <strong>h(n) = heurística</strong>: Estimación en línea recta desde esa ciudad hasta el destino (usando coordenadas GPS).</li>
                    <li>• <strong>f(n) = g(n) + h(n)</strong>: El algoritmo siempre prioriza la ciudad con el <strong>f(n) más bajo</strong>.</li>
                    <li>• <strong>Más eficiente</strong>: Evita explorar rutas que van en dirección contraria.</li>
                </ul>
            </div>
            
            <div class="p-4 bg-emerald-50 rounded-xl border border-emerald-100">
                <h5 class="flex items-center gap-2 font-bold text-emerald-700 mb-2">
                    <span class="material-symbols-outlined">smart_toy</span>
                    Actualmente: Explorando con A*
                </h5>
                <p class="text-sm text-emerald-800">
                    El algoritmo está calculando <strong>g + h</strong> desde <strong>@originCity</strong>: 
                    el costo_real_acumulado más la <strong>distancia_en_línea_recta</strong> estimada hasta <strong>@destinationCity</strong>. 
                    ¡Por eso encuentra el destino más rápido!
                </p>
            </div>
        }
    </div>
</div>

@if (result != null && result.ExplorationSteps != null && result.ExplorationSteps.Count > 0)
{
    <div class="insight-card mb-12">
        <div class="insight-icon">
            <span class="material-symbols-outlined">account_tree</span>
        </div>
        <div class="insight-content">
            <h4>Proceso de Búsqueda</h4>
            
            <div class="flex gap-2 mb-4">
                <button class="px-4 py-2 rounded-lg font-bold text-sm transition-all @(activeTab == 0 ? "bg-indigo-600 text-white" : "bg-slate-100 text-slate-600 hover:bg-slate-200")" @onclick="() => activeTab = 0">
                    <span class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">list</span>
                        Paso a Paso
                    </span>
                </button>
                <button class="px-4 py-2 rounded-lg font-bold text-sm transition-all @(activeTab == 1 ? "bg-indigo-600 text-white" : "bg-slate-100 text-slate-600 hover:bg-slate-200")" @onclick="() => activeTab = 1">
                    <span class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">hub</span>
                        Árbol de Decisión
                    </span>
                </button>
            </div>

            @if (activeTab == 0)
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm border-collapse">
                        <thead>
                            <tr class="bg-slate-100">
                                <th class="p-3 text-left font-bold text-slate-700 rounded-tl-lg">#</th>
                                <th class="p-3 text-left font-bold text-slate-700">Ciudad</th>
                                <th class="p-3 text-left font-bold text-slate-700">G (km)</th>
                                @if (algorithm == 1)
                                {
                                    <th class="p-3 text-left font-bold text-slate-700">H (km)</th>
                                    <th class="p-3 text-left font-bold text-slate-700">F = G+H</th>
                                }
                                <th class="p-3 text-left font-bold text-slate-700 rounded-tr-lg">Explicación</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in result.ExplorationSteps)
                            {
                                var isFinal = result.ExplorationSteps.LastOrDefault()?.City == step.City && step.City == destinationCity;
                                <tr class="@(isFinal ? "bg-emerald-50 border-l-4 border-l-emerald-500" : "border-b border-slate-100")">
                                    <td class="p-3 font-mono text-slate-600">@step.Step</td>
                                    <td class="p-3 font-bold text-slate-800">@step.City</td>
                                    <td class="p-3 font-mono text-indigo-600">@step.G.ToString("F1")</td>
                                    @if (algorithm == 1)
                                    {
                                        <td class="p-3 font-mono text-purple-600">@step.H.ToString("F1")</td>
                                        <td class="p-3 font-mono font-bold text-emerald-600">@step.F.ToString("F1")</td>
                                    }
                                    <td class="p-3 text-slate-600">@step.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-6 bg-slate-50 rounded-xl border border-slate-200">
                    <div class="text-center mb-4">
                        <span class="text-xs text-slate-500 font-bold uppercase tracking-widest">Árbol de Exploración</span>
                    </div>
                    <div class="flex flex-col items-center gap-2">
                        @{
                            var stepGroups = result.ExplorationSteps
                                .GroupBy(s => s.FromCity)
                                .OrderBy(g => g.Key == "-" ? 0 : 1)
                                .ToList();
                        }
                        @foreach (var group in stepGroups)
                        {
                            <div class="flex flex-col items-center gap-1">
                                @if (group.Key != "-")
                                {
                                    <div class="text-xs text-slate-400">← @group.Key</div>
                                }
                                <div class="bg-white border-2 border-indigo-500 rounded-lg px-3 py-2 shadow-sm flex gap-2 flex-wrap justify-center">
                                    @foreach (var step in group)
                                    {
                                        <span class="text-sm font-bold text-indigo-700">@step.City</span>
                                        <span class="text-xs text-slate-400">(@step.F.ToString("F1"))</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<string>? availableCities;
    private string originCity = "";
    private string destinationCity = "";
    private int algorithm = 1;
    private int activeTab = 0;

    private PathResultDto? result;
    private bool isLoading;
    private string? errorMsg;

    private bool IsButtonDisabled => 
        string.IsNullOrEmpty(originCity) || 
        string.IsNullOrEmpty(destinationCity) || 
        originCity == destinationCity;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableCities = await Http.GetFromJsonAsync<List<string>>("api/CityRouting/cities");
        }
        catch (Exception ex)
        {
            errorMsg = "Error al cargar las ciudades: " + ex.Message;
        }
    }

    private void SwapCities()
    {
        if (string.IsNullOrEmpty(originCity) && string.IsNullOrEmpty(destinationCity)) return;
        var temp = originCity;
        originCity = destinationCity;
        destinationCity = temp;
        result = null;
    }

    private async Task CalculateRoute()
    {
        isLoading = true;
        errorMsg = null;
        result = null;

        // Pequeño retraso artificial para que se vea la animación de "Calculando..." y la experiencia sea más premium
        await Task.Delay(600);

        try
        {
            var request = new {
                StartCity = originCity,
                TargetCity = destinationCity,
                Algorithm = algorithm // Siempre enviará 1 (AStar)
            };

            var response = await Http.PostAsJsonAsync("api/CityRouting/calculate", request);
            
            if (response.IsSuccessStatusCode)
            {
                result = await response.Content.ReadFromJsonAsync<PathResultDto>();
            }
            else
            {
                errorMsg = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMsg = "Error de red al calcular la ruta: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    public class PathResultDto
    {
        public bool IsSuccessful { get; set; }
        public List<string> RouteDescriptions { get; set; } = new();
        public double TotalDistanceKm { get; set; }
        public string Message { get; set; } = string.Empty;
        public List<ExplorationStepDto> ExplorationSteps { get; set; } = new();
    }

    public class ExplorationStepDto
    {
        public int Step { get; set; }
        public string City { get; set; } = "";
        public double G { get; set; }
        public double H { get; set; }
        public double F { get; set; }
        public string FromCity { get; set; } = "";
        public string Reason { get; set; } = "";
    }
}
