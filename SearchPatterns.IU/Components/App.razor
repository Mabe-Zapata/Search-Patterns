<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["SearchPatterns.IU.styles.css"]" />
    
    <!-- User Custom Tailwind and Fonts -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary-fixed-dim": "#b8c4ff", "error": "#ba1a1a", "on-error": "#ffffff", "surface-tint": "#3755c3",
                        "secondary-fixed-dim": "#b7c8e1", "primary-fixed": "#dde1ff", "on-surface-variant": "#444653",
                        "on-primary-container": "#a8b8ff", "surface-container-highest": "#e0e3e5", "on-background": "#191c1e",
                        "surface": "#f7f9fb", "on-secondary-fixed-variant": "#38485d", "surface-container-low": "#f2f4f6",
                        "tertiary-fixed": "#ffddb8", "on-secondary": "#ffffff", "secondary-container": "#d0e1fb",
                        "tertiary-fixed-dim": "#ffb95f", "error-container": "#ffdad6", "tertiary-container": "#6b4200",
                        "secondary-fixed": "#d3e4fe", "surface-container": "#eceef0", "on-secondary-fixed": "#0b1c30",
                        "primary-container": "#1e40af", "surface-variant": "#e0e3e5", "on-secondary-container": "#54647a",
                        "on-primary-fixed-variant": "#173bab", "on-surface": "#191c1e", "tertiary": "#4c2e00",
                        "inverse-surface": "#2d3133", "on-tertiary-fixed": "#2a1700", "on-primary": "#ffffff",
                        "background": "#f7f9fb", "outline-variant": "#c4c5d5", "surface-bright": "#f7f9fb",
                        "on-tertiary-container": "#ffa929", "primary": "#00288e", "surface-dim": "#d8dadc",
                        "outline": "#757684", "on-tertiary-fixed-variant": "#653e00", "on-error-container": "#93000a",
                        "secondary": "#505f76", "inverse-on-surface": "#eff1f3", "surface-container-high": "#e6e8ea",
                        "surface-container-lowest": "#ffffff", "on-tertiary": "#ffffff", "inverse-primary": "#b8c4ff",
                        "on-primary-fixed": "#001453"
                    },
                    "borderRadius": { "DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.75rem", "full": "0.75rem" },
                    "fontFamily": { "headline": ["Manrope"], "body": ["Inter"], "label": ["Inter"] }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f7f9fb; }
        .font-headline { font-family: 'Manrope', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .glass-nav { backdrop-filter: blur(20px); }
    </style>

    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body class="text-on-surface">
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="app.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
